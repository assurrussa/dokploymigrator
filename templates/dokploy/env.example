MIGRATOR_IMAGE=ghcr.io/assurrussa/dokploy-migrator:latest
MIGRATOR_HTTP_PORT=8080

MIGRATOR_BASIC_USER=admin
MIGRATOR_BASIC_PASSWORD=replace-with-strong-password
MIGRATOR_ADMIN_TOKEN=replace-with-strong-token

DOKPLOY_POSTGRES_DSN=postgres://dokploy:replace-with-postgres-password@dokploy-postgres:5432/dokploy?sslmode=disable
MIGRATOR_SCHEMA_ALLOWLIST=
MIGRATOR_DEAD_AFTER=10m

DOKPLOY_API_BASE_URL=
DOKPLOY_API_TOKEN=
DOKPLOY_HEALTH_PATH=/health
DOKPLOY_DEPLOY_PATH=
