MIGRATOR_HTTP_PORT=8080
MIGRATOR_BASIC_USER=admin
MIGRATOR_BASIC_PASSWORD=
MIGRATOR_ADMIN_TOKEN=
MIGRATOR_DEAD_AFTER=10m

# Persistent state is set by docker-compose.yml:
# MIGRATOR_STATE_PATH=/data/dokploy-migrator.sqlite

# Required before scanning servers or running plan/apply/rollback.
# Example for a Dokploy Postgres service reachable from this container:
# DOKPLOY_POSTGRES_DSN=postgres://dokploy:password@dokploy-postgres:5432/dokploy?sslmode=disable
DOKPLOY_POSTGRES_DSN=

# Optional Dokploy API health-check integration.
# For standard Dokploy install, this is usually reachable from dokploy-network:
# DOKPLOY_API_BASE_URL=http://dokploy:3000/api
DOKPLOY_API_BASE_URL=
DOKPLOY_API_TOKEN=
DOKPLOY_HEALTH_PATH=/health
# Reserved for a version-specific deploy adapter. Leave unchanged unless you
# have verified a compatible endpoint for your Dokploy version.
DOKPLOY_DEPLOY_PATH=

# Comma-separated schema hashes. Leave empty when using explicit schemaHash
# approval from the UI.
MIGRATOR_SCHEMA_ALLOWLIST=
